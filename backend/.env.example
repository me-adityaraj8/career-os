# ---- Backend environment ----
# Copy to .env and fill in values. Never commit the real .env.

NODE_ENV=development
PORT=4000

# Postgres connection. When running via docker-compose, host is `db`.
# For local (non-Docker) dev, point this at your local Postgres instance.
DATABASE_URL=postgres://rys:rys_dev_password@localhost:5432/rys

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ---- AI gateway (provider-agnostic) ----
# Leave every key blank to run AI features in MOCK mode. Set at least one to go
# live. Providers are tried in AI_PROVIDER_ORDER, falling through on failure.
#
# Default provider: Google Gemini (generous free tier). Get a key at
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional fallbacks (used automatically if the one before is down/rate-limited):
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Optional overrides (sensible defaults shown):
# GEMINI_MODEL=gemini-2.5-flash
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENROUTER_MODEL=google/gemini-2.5-flash
# AI_PROVIDER_ORDER=gemini,groq,openrouter
# AI_TIMEOUT_MS=30000
# AI_MAX_RETRIES=2

# CORS — the frontend origin allowed to call the API
CORS_ORIGIN=http://localhost:5173

# Where uploaded resume PDFs are stored (relative to backend root)
UPLOAD_DIR=uploads
