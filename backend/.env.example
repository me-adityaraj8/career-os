# ---- Backend environment ----
# Copy to .env and fill in values. Never commit the real .env.

NODE_ENV=development
PORT=4000

# Postgres connection. When running via docker-compose, host is `db`.
# For local (non-Docker) dev, point this at your local Postgres instance.
DATABASE_URL=postgres://rys:rys_dev_password@localhost:5432/rys

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# LLM (Anthropic). Leave ANTHROPIC_API_KEY blank to run AI features in MOCK mode.
# When set, the backend calls the real Anthropic API.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# CORS — the frontend origin allowed to call the API
CORS_ORIGIN=http://localhost:5173

# Where uploaded resume PDFs are stored (relative to backend root)
UPLOAD_DIR=uploads
