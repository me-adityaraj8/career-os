# ---- Frontend environment ----
# Base URL of the backend API (include the /api/v1 prefix).
VITE_API_URL=http://localhost:4000/api/v1

# ---- Analytics (optional) ----
# Umami page-view tracking. Leave both blank to disable — no script loads,
# nothing is tracked. Fill in after deploying your own Umami instance.
# VITE_UMAMI_SRC=https://umami.yourdomain.com/script.js
# VITE_UMAMI_WEBSITE_ID=00000000-0000-0000-0000-000000000000
